# Doxyfile 1.12+ for CiPhyxs Physics Engine
# Run: cmake -B build && cmake --build build --target doc

PROJECT_NAME           = "CiPhyxs"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Header-only C++20 physics engine for high-mass-ratio industrial simulation"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/doxygen
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/include/ciphyxs \
                         @CMAKE_CURRENT_SOURCE_DIR@/README.md
FILE_PATTERNS          = *.hpp
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
CASE_SENSE_NAMES       = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
INPUT_ENCODING         = UTF-8
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
ALPHABETICAL_INDEX     = YES
GENERATE_TREEVIEW      = YES
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCHENGINE           = YES
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_HEADER            =
HTML_FOOTER            =
HTML_STYLESHEET        =
HTML_EXTRA_STYLESHEET  =
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_TIMESTAMP         = NO
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = NO
DISABLE_INDEX          = NO
GENERATE_TAGFILE       = @CMAKE_CURRENT_BINARY_DIR@/ciphyxs.tag
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/README.md
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 0
DOT_TRANSPARENT        = YES
CLASS_DIAGRAMS         = YES
HIDE_UNDOC_RELATIONS   = YES
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
TEMPLATE_RELATIONS     = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
INCLUDED_BY_GRAPH      = NO
INCLUDE_GRAPH          = NO
DIRECTORY_GRAPH        = NO
